# ---------------------------------------------------------------
# /api/contact/demo (and any future contact form) sends email via
# SMTP using nodemailer. Set these in .env.local for dev or as
# secrets in your hosting provider (Vercel etc.) for production.
#
# When these vars are NOT set, the route falls back to logging
# submissions to the server console and still returns 200, so the
# form works in dev without credentials.
# ---------------------------------------------------------------

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=demo@xbert.ai
SMTP_PASSWORD=replace-me
SMTP_FROM="XBert Demo <demo@xbert.ai>"

# Optional — defaults to gorny@nextiva.com.
DEMO_TO_EMAIL=gorny@nextiva.com
